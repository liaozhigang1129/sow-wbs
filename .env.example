# ============ 服务端口 ============
PORT=8787
HOST=0.0.0.0

# ============ 默认 LLM（用户在 UI 配置后保存到 localStorage，前端请求时回传） ============
# DEFAULT_PROVIDER=openai
# DEFAULT_BASE_URL=https://api.openai.com/v1
# DEFAULT_MODEL=gpt-4o

# ⭐ v2.19: 服务端 fallback 用的 API Key（前端没传时自动使用）
# 同时被 /api/generate、/api/v1/wbs/generate、MCP wbs_generate 共用
# HEXAI_API_KEY=sk-xxxxxxxxxxxxxxxx
# HEXAI_BASE_URL=https://crs.hexai.cn/v1
# LLM_OPENAI_API_KEY=
# LLM_CLAUDE_API_KEY=
# ANTHROPIC_API_KEY=
# LLM_QWEN_API_KEY=

# ============ v2.19: 公开 API v1 鉴权 ============
# 多个 key 用英文逗号分隔；留空 → 开发模式（v1 路由免鉴权，仅在日志中提示）
# WBS_API_KEYS=demo-key-1,demo-key-2
# 每分钟每个 key 的请求数上限（默认 60）
# WBS_RATE_LIMIT_PER_MIN=60

# ============ v2.19: MCP Server ============
# HTTP+SSE 模式下，可选的鉴权 Bearer / X-API-Key
# 与 WBS_API_KEYS 的 key 单独维护，留空 → 开放（开发友好）
# MCP_API_KEY=

# stdio 模式：直接 `node bin/mcp-server.js`，Claude Desktop / Cursor 配置见 docs/MCP.md
